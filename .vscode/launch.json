{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Spring Boot: Debug (Attach via Maven)",
            "type": "java",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005,
            "preLaunchTask": "spring-boot:run-debug"
        },
        {
            "name": "Spring Boot: Launch (Java Extension)",
            "type": "java",
            "request": "launch",
            "mainClass": "home03.tfr.SpringOauth2jwt.SpringOauth2jwtApplication",
            "projectName": "SpringOauth2jwt",
            "console": "integratedTerminal"
        }
    ]
}
